<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleorder_document_inherit_store" inherit_id="sale.report_saleorder_document">
        <xpath expr="//t[@t-set='address']" position="before">
            <!-- Verificamos si la orden tiene equipo y si ese equipo tiene un partner asignado -->
            <t t-if="doc.team_id and doc.team_id.store_partner_id">
                <div class="row mb-3" name="store_address_header">
                    <div class="col-7">
                        <strong style="text-transform: uppercase; color: #714B67;">Sucursal de Venta:</strong>
                        <div style="font-size: 1.1em; font-weight: bold;">
                            <span t-field="doc.team_id.store_partner_id.name"/>
                        </div>
                        
                        <!-- Widget contact para traer dirección, tel y mail del local de forma limpia -->
                        <div t-field="doc.team_id.store_partner_id"
                             t-options='{"widget": "contact", "fields": ["address", "phone", "email"], "no_marker": True}'/>
                    </div>
                </div>
                <hr/>
            </t>
        </xpath>
    </template>
</odoo>