<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1"> 
        <!-- Regla para Diarios: Globales o de la Tienda del usuario -->
        <record id="journal_restricted_access_rule" model="ir.rule">
            <field name="name">Acceso Restringido a Diarios por Store Team</field>
            <field name="model_id" ref="account.model_account_journal"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|', ('store_team_ids', '=', False), ('store_team_ids', 'in', [user.sale_team_id.id])]
            </field>
        </record>

        <!-- Regla para Asientos/Facturas: Basada en el diario -->
        <record id="account_move_restricted_access_rule" model="ir.rule">
            <field name="name">Acceso Restringido a Asientos por Store Team</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|', ('journal_id.store_team_ids', '=', False), ('journal_id.store_team_ids', 'in', [user.sale_team_id.id])]
            </field>
        </record>
        
        <!-- Regla para Almacenes: Para que no vean stock de otros locales -->
        <!-- <record id="warehouse_restricted_access_rule" model="ir.rule">
            <field name="name">Acceso Restringido a Almacenes por Store Team</field>
            <field name="model_id" ref="stock.model_stock_warehouse"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|', ('store_team_ids', '=', False), ('store_team_ids', 'in', [user.sale_team_id.id])]
            </field>
        </record> -->
    </data>
</odoo>